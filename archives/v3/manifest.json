{
  "manifest_version": 3,
  "name": "FB Messenger 提醒",
  "version": "3.0",
  "description": "FB Business 私訊提醒 + 轉發 Telegram",
  "permissions": ["storage", "notifications", "offscreen"],
  "host_permissions": [
    "https://business.facebook.com/*",
    "https://www.facebook.com/*",
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://business.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
